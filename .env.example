# --- PostgreSQL ---
# Local docker:  docker run --name deploy-sa-db -e POSTGRES_PASSWORD=postgres -e POSTGRES_DB=deploysa -p 5432:5432 -d postgres:16
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/deploysa?schema=public"

# --- Auth.js ---
# Generate with:  npx auth secret   (or)  openssl rand -base64 32
AUTH_SECRET="replace-me-with-a-random-32-byte-string"

# --- GitHub OAuth App ---
# Create at: https://github.com/settings/developers  ->  New OAuth App
#   Homepage URL:               http://localhost:3000
#   Authorization callback URL: http://localhost:3000/api/auth/callback/github
AUTH_GITHUB_ID="your-github-oauth-client-id"
AUTH_GITHUB_SECRET="your-github-oauth-client-secret"
