# Production .env for deploy.wafgate.com  (copy to .env on the server)

# Neon PostgreSQL
DATABASE_URL="postgresql://neondb_owner:PASSWORD@ep-broad-haze-at5p1bz0.c-9.us-east-1.aws.neon.tech/neondb?sslmode=require"

# Auth.js — generate with: npx auth secret
AUTH_SECRET="replace-with-a-fresh-random-secret"

# Public URL of the app (used by Auth.js for OAuth callbacks)
AUTH_URL="https://deploy.wafgate.com"
AUTH_TRUST_HOST="true"

# GitHub OAuth App (callback: https://deploy.wafgate.com/api/auth/callback/github)
AUTH_GITHUB_ID="your-prod-client-id"
AUTH_GITHUB_SECRET="your-prod-client-secret"

# --- Real deployment pipeline (Alibaba ECS build agent) ---
# Leave AGENT_URL empty to keep deployments simulated.
AGENT_URL="http://<ecs-public-ip>:9000"
AGENT_TOKEN="same-long-random-string-as-the-agent"
APPS_DOMAIN="apps.deploy.wafgate.com"
