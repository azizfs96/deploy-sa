# Build agent config (on the Alibaba ECS host)
AGENT_PORT=9000
# Shared secret — must match AGENT_TOKEN in the control plane's .env
AGENT_TOKEN=replace-with-a-long-random-string
# Wildcard apps domain (DNS: *.apps.deploy.wafgate.com -> ECS IP)
APPS_DOMAIN=apps.deploy.wafgate.com
# Docker network shared with Traefik
DOCKER_NETWORK=web
# Traefik ACME resolver name (matches docker-compose: "le")
TRAEFIK_CERT_RESOLVER=le
# Where repos are cloned/built (ephemeral)
BUILD_ROOT=/var/deploysa/builds
